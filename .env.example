# .env.example
# No API keys or credentials are required to run this pipeline.
# All data sources are publicly accessible (DSS via HTTPS, CCAV via browser).
#
# Optional overrides — copy this file to .env and uncomment as needed:

# Path to Chrome (used only if RENDER_PDF = TRUE in config.R)
# CHROME=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Override Rscript location (default: first Rscript on PATH)
# RSCRIPT=/usr/local/bin/Rscript

# Override Quarto location (default: first quarto on PATH)
# QUARTO=/usr/local/bin/quarto
